export const dynamic = "force-dynamic"

const createTreatmentPlanSchema = z.object({
  patientId: z.string().uuid(),
  title: z.string(),
  description: z.string().optional(),
  priority: z.string().default("intermediate"),
  notes: z.string().optional(),
})


// Dynamic form templates (admin-configurable)
// Used to render check-in forms, data completion requests, and ad-hoc signable documents.
model FormTemplate {
  id                          String   @id @default(uuid()) @db.Uuid
  // Unique per-row key (backwards compatible). When versioning, a new row gets a distinct
  // key like `${familyKey}-v2` while familyKey groups all versions of the template family.
  key                         String   @unique @db.VarChar(100)
  // Family key groups related versions together. NULL = standalone (the key itself IS the family).
  familyKey                   String?  @map("family_key") @db.VarChar(100)
  // Version number within a key family. v1 is the original; v2, v3... are revisions.
  version                     Int      @default(1)
  // Lifecycle: draft (in progress) | active (current live) | inactive (paused, not auto-attached) | archived (superseded by a newer version)
  status                      FormTemplateStatus @default(active)
  // When this version became/becomes the effective template for new signings
  effectiveDate               DateTime? @map("effective_date") @db.Timestamptz(6)
  // Nullable pointer to the previous-version row that this row replaces
  supersedesId                String?  @map("supersedes_id") @db.Uuid
  supersedes                  FormTemplate? @relation("FormTemplateRevision", fields: [supersedesId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supersededBy                FormTemplate[] @relation("FormTemplateRevision")
  title                       String   @db.VarChar(200)
  description                 String?
  category                    String   @db.VarChar(50)
  fields                      Json
  requiredForAppointmentTypes Json?    @map("required_for_appointment_types")
  requiredForTreatmentIds     Json?    @map("required_for_treatment_ids")
  requiredForTreatmentCategories Json? @map("required_for_treatment_categories")
  requiredForServiceIds       Json?    @map("required_for_service_ids")
  requiredForPackageTemplateIds Json?  @map("required_for_package_template_ids")
  // Requirement stage(s): any of `check_in`, `before_procedure`, `before_payment`, `discharge`.
  // Stored as JSON array for multi-stage flexibility. Null/empty = legacy (check_in only).
  requirementStages           Json?    @map("requirement_stages")
  // Patient-eligibility rules
  minorOnly                   Boolean  @default(false) @map("minor_only")
  adultOnly                   Boolean  @default(false) @map("adult_only")
  requiresGuardian            Boolean  @default(false) @map("requires_guardian")
  requiredAlways              Boolean  @default(false) @map("required_always")
  isActive                    Boolean  @default(true) @map("is_active")
  isSystem                    Boolean  @default(false) @map("is_system")
  displayOrder                Int      @default(0) @map("display_order")
  createdAt                   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([familyKey])
  @@index([category])
  @@index([isActive])
  @@index([status])
  @@map("form_templates")
}

// ============================================================
// Chart Entries — General & Ortho charting system (Phase 1)
// ============================================================
model ChartEntry {
  id                String    @id @default(uuid()) @db.Uuid
  patientId         String    @map("patient_id") @db.Uuid
  chartType         String    @map("chart_type") @db.VarChar(20)   // 'general' | 'ortho'
  entryNumber       Int       @map("entry_number")
  visitDate         DateTime  @map("visit_date") @db.Timestamptz(6)

  // General chart fields
  toothNumber       String?   @map("tooth_number") @db.VarChar(20)
  surface           String?   @db.VarChar(50)
  diagnosis         String?
  procedureName     String?   @map("procedure_name") @db.VarChar(300)
  treatmentId       String?   @map("treatment_id") @db.Uuid

  // Ortho chart fields
  wire              String?   @db.VarChar(200)

  // Shared fields
  notes             String?
  amountCharged     Decimal   @default(0) @map("amount_charged") @db.Decimal(10, 2)
  amountPaid        Decimal   @default(0) @map("amount_paid") @db.Decimal(10, 2)
  runningBalance    Decimal   @default(0) @map("running_balance") @db.Decimal(10, 2)
  status            String    @default("signed") @db.VarChar(30)   // 'draft' | 'signed' | 'amended'

  // Dentist
  dentistId         String?   @map("dentist_id") @db.Uuid
  dentistName       String?   @map("dentist_name") @db.VarChar(200)

  // Next visit
  nextVisitDate     DateTime? @map("next_visit_date") @db.Timestamptz(6)
  nextVisitNotes    String?   @map("next_visit_notes")
  autoAppointmentId String?   @map("auto_appointment_id") @db.Uuid

  // Package deduction
  packageId         String?   @map("package_id") @db.Uuid
  deductedFromPackage Boolean @default(false) @map("deducted_from_package")
  packageDeductionAmount Decimal @default(0) @map("package_deduction_amount") @db.Decimal(10, 2)

  // Linked records (created during sync)
  visitRecordId     String?   @map("visit_record_id") @db.Uuid
  procedureRecordId String?   @map("procedure_record_id") @db.Uuid
  paymentId         String?   @map("payment_id") @db.Uuid

  // Nested add-on support (child entries for bundled same-visit procedures with separate payments)
  parentEntryId     String?   @map("parent_entry_id") @db.Uuid
  parent            ChartEntry?  @relation("ChartEntryNesting", fields: [parentEntryId], references: [id], onDelete: SetNull)
  children          ChartEntry[] @relation("ChartEntryNesting")

  createdBy         String?   @map("created_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Edit tracking
  lastEditedBy      String?   @map("last_edited_by") @db.VarChar(200)
  editHistory       Json?     @map("edit_history")   // Array of { editedBy, editedAt, before, after }

  // Patient signature (base64 data URI captured on completion)
  patientSignature  String?   @map("patient_signature")
  signedAt          DateTime? @map("signed_at") @db.Timestamptz(6)
  signedByName      String?   @map("signed_by_name") @db.VarChar(200)

  patient           Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, chartType, visitDate])
  @@index([patientId, chartType, entryNumber])
  @@index([parentEntryId])
  @@map("chart_entries")
}
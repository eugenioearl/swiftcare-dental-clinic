model SmartUpload {
  id                String    @id @default(uuid()) @db.Uuid
  patientId         String    @map("patient_id") @db.Uuid
  fileName          String    @map("file_name") @db.VarChar(500)
  originalName      String    @map("original_name") @db.VarChar(500)
  mimeType          String?   @map("mime_type") @db.VarChar(100)
  fileSize          Int?      @map("file_size")
  cloudStoragePath  String    @map("cloud_storage_path")
  extractedData     Json?     @map("extracted_data")
  extractionStatus  String    @default("pending") @map("extraction_status") @db.VarChar(20)
  classification    String?   @map("classification") @db.VarChar(50)
  classificationConfidence Float? @map("classification_confidence")
  confidenceScores  Json?     @map("confidence_scores")
  reviewedBy        String?   @map("reviewed_by") @db.Uuid
  reviewedAt        DateTime? @map("reviewed_at") @db.Timestamptz(6)
  reviewNotes       String?   @map("review_notes")
  savedToRecords    Boolean   @default(false) @map("saved_to_records")
  migrationStatus   String    @default("uploaded") @map("migration_status") @db.VarChar(20)
  targetType        String?   @map("target_type") @db.VarChar(50)
  targetId          String?   @map("target_id") @db.Uuid
  uploadedBy        String    @map("uploaded_by") @db.Uuid
  // ====================== OCR (Tesseract) fields ======================
  // These are additive and optional. They support the OCR feature without
  // breaking any existing extraction/AI flows. OCR runs on demand or after
  // upload for image-type files; results are cached so we never re-run on the
  // same file unless the user explicitly re-runs.
  ocrStatus         String?   @map("ocr_status") @db.VarChar(20)         // pending | processing | completed | failed | skipped
  ocrText           String?   @map("ocr_text")                            // Full extracted plain text
  ocrConfidence     Float?    @map("ocr_confidence")                      // 0-100 average confidence
  ocrFields         Json?     @map("ocr_fields")                          // Structured fields detected via regex/heuristics
  ocrLanguage       String?   @map("ocr_language") @db.VarChar(20)        // Tesseract language code(s) used
  ocrError          String?   @map("ocr_error") @db.VarChar(500)          // Last error message if failed
  ocrProcessedAt    DateTime? @map("ocr_processed_at") @db.Timestamptz(6)
  ocrProcessedBy    String?   @map("ocr_processed_by") @db.Uuid
  // ====================== End OCR fields ==============================
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  patient           Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
  @@index([extractionStatus])
  @@index([ocrStatus])
  @@map("smart_uploads")
}


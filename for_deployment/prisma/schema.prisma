// ===============================
// TREATMENT & PAYMENT WORKFLOW
// ===============================

enum PackageStatus {
  draft
  active
  in_progress
  completed
  cancelled
}

enum PackageItemStatus {
  pending
  scheduled
  in_progress
  completed
  cancelled
}

enum CoverageType {
  fully_covered
  partially_covered
  not_covered
}

enum PatientPaymentType {
  visit_payment
  package_installment
  deposit
  refund
}

enum PatientPaymentStatus {
  pending
  completed
  cancelled
  refunded
}

model TreatmentPackage {
  id                String        @id @default(uuid()) @db.Uuid
  patientId         String        @map("patient_id") @db.Uuid
  packageNumber     String        @unique @map("package_number") @db.VarChar(20)
  title             String        @db.VarChar(200)
  description       String?
  status            PackageStatus @default(draft)
  totalAmount       Decimal       @default(0.00) @map("total_amount") @db.Decimal(10, 2)
  coveredAmount     Decimal       @default(0.00) @map("covered_amount") @db.Decimal(10, 2)
  patientPayable    Decimal       @default(0.00) @map("patient_payable") @db.Decimal(10, 2)
  paidAmount        Decimal       @default(0.00) @map("paid_amount") @db.Decimal(10, 2)
  balanceDue        Decimal       @default(0.00) @map("balance_due") @db.Decimal(10, 2)
  createdById       String?       @map("created_by_id") @db.Uuid
  notes             String?
  startDate         DateTime?     @map("start_date") @db.Date
  expectedEndDate   DateTime?     @map("expected_end_date") @db.Date
  completedDate     DateTime?     @map("completed_date") @db.Date
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  coverageActivation String?       @default("on_signature") @map("coverage_activation") @db.VarChar(30)
  isSigned          Boolean       @default(false) @map("is_signed")
  signedAt          DateTime?     @map("signed_at") @db.Timestamptz(6)
  revisedFromId     String?       @map("revised_from_id") @db.Uuid
  revisionNumber    Int           @default(0) @map("revision_number")
  sourcePackageTemplateId String? @map("source_package_template_id") @db.Uuid
  patient           Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdBy         User?         @relation(fields: [createdById], references: [id])
  revisedFrom       TreatmentPackage?  @relation("PackageRevisions", fields: [revisedFromId], references: [id])
  revisions         TreatmentPackage[] @relation("PackageRevisions")
  items             PackageItem[]
  payments          PatientPayment[]
  consentForms      ConsentForm[]

  @@index([patientId, status])
  @@index([packageNumber])
  @@index([status])
  @@map("treatment_packages")
}

model PackageItem {
  id                String            @id @default(uuid()) @db.Uuid
  packageId         String            @map("package_id") @db.Uuid
  treatmentId       String?           @map("treatment_id") @db.Uuid
  procedureName     String            @map("procedure_name") @db.VarChar(200)
  toothNumber       String?           @map("tooth_number") @db.VarChar(10)
  surface           String?           @db.VarChar(50)
  quantity          Int               @default(1)
  unitCost          Decimal           @default(0.00) @map("unit_cost") @db.Decimal(10, 2)
  adjustedCost      Decimal           @default(0.00) @map("adjusted_cost") @db.Decimal(10, 2)
  coverageType      CoverageType      @default(not_covered) @map("coverage_type")
  coveredAmount     Decimal           @default(0.00) @map("covered_amount") @db.Decimal(10, 2)
  patientCost       Decimal           @default(0.00) @map("patient_cost") @db.Decimal(10, 2)
  status            PackageItemStatus @default(pending)
  sortOrder         Int               @default(0) @map("sort_order")
  notes             String?
  completedDate     DateTime?         @map("completed_date") @db.Date
  appointmentId     String?           @map("appointment_id") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  package           TreatmentPackage  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  treatment         Treatment?        @relation(fields: [treatmentId], references: [id])
  appointment       Appointment?      @relation(fields: [appointmentId], references: [id])

  @@index([packageId, status])
  @@index([treatmentId])
  @@index([appointmentId])
  @@map("package_items")
}

model PatientPayment {
  id                String               @id @default(uuid()) @db.Uuid
  patientId         String               @map("patient_id") @db.Uuid
  packageId         String?              @map("package_id") @db.Uuid
  appointmentId     String?              @map("appointment_id") @db.Uuid
  paymentNumber     String               @unique @map("payment_number") @db.VarChar(20)
  amount            Decimal              @db.Decimal(10, 2)
  paymentType       PatientPaymentType   @map("payment_type")
  paymentMethod     PaymentMethod        @map("payment_method")
  status            PatientPaymentStatus @default(pending)
  description       String?
  receivedById      String?              @map("received_by_id") @db.Uuid
  notes             String?
  processedAt       DateTime?            @map("processed_at") @db.Timestamptz(6)
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  patient           Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  package           TreatmentPackage?    @relation(fields: [packageId], references: [id])
  appointment       Appointment?         @relation(fields: [appointmentId], references: [id])
  receivedBy        User?                @relation("PaymentReceiver", fields: [receivedById], references: [id])

  @@index([patientId])
  @@index([packageId])
  @@index([appointmentId])
  @@index([paymentNumber])
  @@index([status])
  @@map("patient_payments")
}

// ===============================
// CONSENT & SIGNING SYSTEM
// ===============================

enum ConsentStatus {
  draft
  sent
  viewed
  signed
  expired
  cancelled
}

model ConsentForm {
  id                String        @id @default(uuid()) @db.Uuid
  patientId         String        @map("patient_id") @db.Uuid
  packageId         String?       @map("package_id") @db.Uuid
  appointmentId     String?       @map("appointment_id") @db.Uuid
  consentNumber     String        @unique @map("consent_number") @db.VarChar(20)
  title             String        @db.VarChar(200)
  description       String?
  status            ConsentStatus @default(draft)
  formContent       String?       @map("form_content")
  formFields        Json?         @map("form_fields")
  formResponses     Json?         @map("form_responses")
  treatmentSummary  Json?         @map("treatment_summary")
  financialSummary  Json?         @map("financial_summary")
  patientSignature  String?       @map("patient_signature")
  patientSignedAt   DateTime?     @map("patient_signed_at") @db.Timestamptz(6)
  witnessSignature  String?       @map("witness_signature")
  witnessSignedAt   DateTime?     @map("witness_signed_at") @db.Timestamptz(6)
  witnessId         String?       @map("witness_id") @db.Uuid
  preparedById      String?       @map("prepared_by_id") @db.Uuid
  signingToken      String?       @unique @map("signing_token") @db.VarChar(100)
  tokenExpiresAt    DateTime?     @map("token_expires_at") @db.Timestamptz(6)
  sentAt            DateTime?     @map("sent_at") @db.Timestamptz(6)
  viewedAt          DateTime?     @map("viewed_at") @db.Timestamptz(6)
  expiresAt         DateTime?     @map("expires_at") @db.Timestamptz(6)
  round             Int           @default(1)
  notes             String?
  // Template version snapshot (Phase 2). When a ConsentForm is created from a FormTemplate,
  // we snapshot the template's key + version here so that signed instances are never broken
  // when the template is revised later. All fields nullable for backwards compatibility.
  templateKey       String?       @map("template_key") @db.VarChar(100)
  templateVersion   Int?          @map("template_version")
  // How this form was assigned: 'auto' (auto-attach rules), 'manual', 'data_completion', 'migration'
  assignmentSource  String?       @map("assignment_source") @db.VarChar(30)
  // Which workflow stage triggered this form (check_in, before_procedure, before_payment, discharge)
  requirementStage  String?       @map("requirement_stage") @db.VarChar(40)
  // Guardian signing support (for minors)
  guardianName      String?       @map("guardian_name") @db.VarChar(200)
  guardianRelation  String?       @map("guardian_relation") @db.VarChar(100)
  guardianSignature String?       @map("guardian_signature")
  guardianSignedAt  DateTime?     @map("guardian_signed_at") @db.Timestamptz(6)
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  patient           Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  package           TreatmentPackage? @relation(fields: [packageId], references: [id])
  appointment       Appointment?  @relation(fields: [appointmentId], references: [id])
  preparedBy        User?         @relation("ConsentPreparedBy", fields: [preparedById], references: [id])
  witness           User?         @relation("ConsentWitnessedBy", fields: [witnessId], references: [id])

  @@index([patientId, status])
  @@index([packageId])
  @@index([appointmentId])
  @@index([consentNumber])
  @@index([signingToken])
  @@index([status])
  @@index([templateKey, templateVersion])
  @@map("consent_forms")
}


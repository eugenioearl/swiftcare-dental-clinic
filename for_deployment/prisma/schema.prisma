generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/swiftcare-dental-clinic/app/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id                     String                 @id @default(uuid()) @db.Uuid
  email                  String                 @unique @db.VarChar(255)
  username               String?                @unique @db.VarChar(100)
  passwordHash           String                 @map("password_hash") @db.VarChar(255)
  firstName              String                 @map("first_name") @db.VarChar(100)
  lastName               String                 @map("last_name") @db.VarChar(100)
  phone                  String?                @db.VarChar(20)
  role                   UserRole               @default(patient)
  isActive               Boolean                @default(true) @map("is_active")
  emailVerified          Boolean                @default(false) @map("email_verified")
  emailVerificationToken String?                @map("email_verification_token") @db.VarChar(255)
  passwordResetToken     String?                @map("password_reset_token") @db.VarChar(255)
  passwordResetExpires   DateTime?              @map("password_reset_expires") @db.Timestamptz(6)
  profilePicture         String?                @map("profile_picture") @db.VarChar(500)
  lastLogin              DateTime?              @map("last_login") @db.Timestamptz(6)
  createdAt              DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  accounts               Account[]
  appointmentsCancelled  Appointment[]          @relation("CancelledBy")
  appointmentsCreated    Appointment[]          @relation("CreatedBy")
  auditLogs              AuditLog[]
  announcements          Announcement[] @relation("AnnouncementCreator")
  dentist                Dentist?
  inventoryTransactions  InventoryTransaction[]
  notifications          Notification[]
  patient                Patient?
  sessions               Session[]
  staff                  Staff?
  createdPackages        TreatmentPackage[]
  receivedPayments       PatientPayment[]     @relation("PaymentReceiver")
  preparedConsents       ConsentForm[]        @relation("ConsentPreparedBy")
  witnessedConsents      ConsentForm[]        @relation("ConsentWitnessedBy")
  intakeReviews          IntakeSubmission[]
  createdTemplates       PackageTemplate[]

  @@index([email])
  @@index([role, isActive])
  @@index([createdAt])
  @@map("users")
}

model Patient {
  id                           String                   @id @default(uuid()) @db.Uuid
  userId                       String?                  @unique @map("user_id") @db.Uuid
  patientNumber                String                   @unique @map("patient_number") @db.VarChar(20)
  fullName                     String?                  @map("full_name") @db.VarChar(200)
  firstName                    String?                  @map("first_name") @db.VarChar(100)
  middleName                   String?                  @map("middle_name") @db.VarChar(100)
  lastName                     String?                  @map("last_name") @db.VarChar(100)
  preferredName                String?                  @map("preferred_name") @db.VarChar(100)
  mobileNumber                 String?                  @map("mobile_number") @db.VarChar(20)
  emailDirect                  String?                  @map("email_direct") @db.VarChar(255)
  source                       String?                  @db.VarChar(100)
  campaign                     String?                  @db.VarChar(200)
  dateOfBirth                  DateTime?                @map("date_of_birth") @db.Date
  gender                       Gender?
  civilStatus                  String?                  @map("civil_status") @db.VarChar(30)
  religion                     String?                  @db.VarChar(100)
  address                      String?
  city                         String?                  @db.VarChar(100)
  province                     String?                  @db.VarChar(100)
  state                        String?                  @db.VarChar(50)
  zipCode                      String?                  @map("zip_code") @db.VarChar(10)
  emergencyContactName         String?                  @map("emergency_contact_name") @db.VarChar(200)
  emergencyContactPhone        String?                  @map("emergency_contact_phone") @db.VarChar(20)
  emergencyContactRelationship String?                  @map("emergency_contact_relationship") @db.VarChar(50)
  medicalHistory               String?                  @map("medical_history")
  allergies                    String?
  currentMedications           String?                  @map("current_medications")
  insuranceProvider            String?                  @map("insurance_provider") @db.VarChar(200)
  insurancePolicyNumber        String?                  @map("insurance_policy_number") @db.VarChar(100)
  insuranceGroupNumber         String?                  @map("insurance_group_number") @db.VarChar(100)
  occupation                   String?                  @db.VarChar(200)
  nationality                  String?                  @db.VarChar(100)
  remarks                      String?
  dentalAnxieties              String?                  @map("dental_anxieties")
  previousDentist              String?                  @map("previous_dentist") @db.VarChar(300)
  previousDentalRemarks        String?                  @map("previous_dental_remarks")
  pregnancyStatus              String?                  @map("pregnancy_status") @db.VarChar(50)
  bloodPressureHistory         String?                  @map("blood_pressure_history")
  medicalSafetyNotes           String?                  @map("medical_safety_notes")
  preferredLanguage            String                   @default("English") @map("preferred_language") @db.VarChar(50)
  communicationPreference      CommunicationPreference? @default(email) @map("communication_preference")
  // Valid ID
  validIdType                  String?                  @map("valid_id_type") @db.VarChar(100)
  validIdNumber                String?                  @map("valid_id_number") @db.VarChar(100)
  // Patient signature (base64 data URI)
  patientSignature             String?                  @map("patient_signature")
  patientSignedAt              DateTime?                @map("patient_signed_at") @db.Timestamptz(6)
  // Last-touch audit metadata
  lastUpdatedById              String?                  @map("last_updated_by_id") @db.Uuid
  lastUpdatedByName            String?                  @map("last_updated_by_name") @db.VarChar(200)
  lastUpdatedSection           String?                  @map("last_updated_section") @db.VarChar(50)
  medicalLastUpdatedAt         DateTime?                @map("medical_last_updated_at") @db.Timestamptz(6)
  medicalLastUpdatedById       String?                  @map("medical_last_updated_by_id") @db.Uuid
  medicalLastUpdatedByName     String?                  @map("medical_last_updated_by_name") @db.VarChar(200)
  // Chart type profile (Phase 1): primary / mixed / permanent. Null = auto-suggest from age.
  currentChartType             DentalChartType?         @map("current_chart_type")
  chartTypeSetById             String?                  @map("chart_type_set_by_id") @db.Uuid
  chartTypeSetAt               DateTime?                @map("chart_type_set_at") @db.Timestamptz(6)
  chartTypeNotes               String?                  @map("chart_type_notes")
  // Social media profiles (JSON array: [{platform, username}])
  socialMedia                  Json?                    @map("social_media")
  // Structured medical data (JSON arrays)
  allergiesList                Json?                    @map("allergies_list")
  conditionsList               Json?                    @map("conditions_list")
  medicationsList              Json?                    @map("medications_list")
  // Patient profile picture (S3 cloud storage)
  profilePicture               String?                  @map("profile_picture") @db.VarChar(500)
  profilePictureCloudPath      String?                  @map("profile_picture_cloud_path") @db.VarChar(500)
  profilePictureUpdatedAt      DateTime?                @map("profile_picture_updated_at") @db.Timestamptz(6)
  isActive                     Boolean                  @default(true) @map("is_active")
  createdAt                    DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                    DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  appointments                 Appointment[]
  billing                      Billing[]
  dentalRecords                DentalRecord[]
  documents                    PatientDocument[]
  user                         User?                    @relation(fields: [userId], references: [id])
  treatmentPlans               TreatmentPlan[]
  visitRecords                 VisitRecord[]
  procedureRecords             ProcedureRecord[]
  dentalChartVersions          DentalChartVersion[]
  clinicalNotes                ClinicalNote[]
  smartUploads                 SmartUpload[]
  treatmentPackages            TreatmentPackage[]
  patientPayments              PatientPayment[]
  consentForms                 ConsentForm[]
  intakeSubmissions            IntakeSubmission[]
  chartEntries                 ChartEntry[]

  @@index([patientNumber])
  @@index([mobileNumber])
  @@index([emailDirect])
  @@index([isActive])
  @@index([insuranceProvider])
  @@index([fullName])
  @@map("patients")
}

model Dentist {
  id                     String          @id @default(uuid()) @db.Uuid
  userId                 String          @unique @map("user_id") @db.Uuid
  licenseNumber          String          @unique @map("license_number") @db.VarChar(50)
  licenseState           String          @map("license_state") @db.VarChar(50)
  licenseExpiryDate      DateTime?       @map("license_expiry_date") @db.Date
  specialization         String?         @db.VarChar(200)
  bio                    String?
  consultationFee        Decimal         @default(0.00) @map("consultation_fee") @db.Decimal(10, 2)
  yearsExperience        Int             @default(0) @map("years_experience")
  education              String?
  certifications         String?
  languagesSpoken        String[]        @default(["English"]) @map("languages_spoken")
  isAvailable            Boolean         @default(true) @map("is_available")
  isAcceptingNewPatients Boolean         @default(true) @map("is_accepting_new_patients")
  createdAt              DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  appointments           Appointment[]
  dentalRecords          DentalRecord[]
  user                   User            @relation(fields: [userId], references: [id])
  schedules              Schedule[]
  treatmentPlans         TreatmentPlan[]

  @@index([licenseNumber])
  @@index([isAvailable])
  @@index([specialization])
  @@map("dentists")
}

model Staff {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  employeeId   String   @unique @map("employee_id") @db.VarChar(20)
  department   String?  @db.VarChar(100)
  position     String?  @db.VarChar(100)
  hourlyRate   Decimal? @map("hourly_rate") @db.Decimal(8, 2)
  hireDate     DateTime @map("hire_date") @db.Date
  supervisorId String?  @map("supervisor_id") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  supervisor   Staff?   @relation("StaffSupervisor", fields: [supervisorId], references: [id])
  subordinates Staff[]  @relation("StaffSupervisor")
  user         User     @relation(fields: [userId], references: [id])

  @@index([employeeId])
  @@index([department])
  @@index([isActive])
  @@map("staff")
}

model Appointment {
  id                    String                 @id @default(uuid()) @db.Uuid
  appointmentNumber     String                 @unique @map("appointment_number") @db.VarChar(20)
  patientId             String                 @map("patient_id") @db.Uuid
  dentistId             String?                @map("dentist_id") @db.Uuid
  createdBy             String?                @map("created_by") @db.Uuid
  serviceId             String?                @map("service_id") @db.Uuid
  service               ClinicService?         @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  scheduledDatetime     DateTime               @map("scheduled_datetime") @db.Timestamptz(6)
  durationMinutes       Int                    @default(30) @map("duration_minutes")
  status                AppointmentStatus      @default(pending_assignment)
  appointmentType       AppointmentType        @map("appointment_type")
  customAppointmentType String?                @map("custom_appointment_type") @db.VarChar(200)
  reasonForVisit        String?                @map("reason_for_visit")
  notes                 String?
  internalNotes         String?                @map("internal_notes")
  estimatedCost         Decimal?               @default(0.00) @map("estimated_cost") @db.Decimal(10, 2)
  isEmergency           Boolean                @default(false) @map("is_emergency")
  source                String?                @db.VarChar(100)
  campaign              String?                @db.VarChar(200)
  patientMatchStatus    String?                @map("patient_match_status") @db.VarChar(50)
  confirmationSentAt    DateTime?              @map("confirmation_sent_at") @db.Timestamptz(6)
  reminderSentAt        DateTime?              @map("reminder_sent_at") @db.Timestamptz(6)
  checkedInAt           DateTime?              @map("checked_in_at") @db.Timestamptz(6)
  startedAt             DateTime?              @map("started_at") @db.Timestamptz(6)
  completedAt           DateTime?              @map("completed_at") @db.Timestamptz(6)
  cancelledAt           DateTime?              @map("cancelled_at") @db.Timestamptz(6)
  cancelledBy           String?                @map("cancelled_by") @db.Uuid
  cancellationReason    String?                @map("cancellation_reason")
  rejectedAt            DateTime?              @map("rejected_at") @db.Timestamptz(6)
  rejectionReason       String?                @map("rejection_reason")
  noShowAt              DateTime?              @map("no_show_at") @db.Timestamptz(6)
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  cancellationFee       Decimal?               @default(0.00) @map("cancellation_fee") @db.Decimal(10, 2)
  appointmentTreatments AppointmentTreatment[]
  canceller             User?                  @relation("CancelledBy", fields: [cancelledBy], references: [id])
  creator               User?                  @relation("CreatedBy", fields: [createdBy], references: [id])
  dentist               Dentist?               @relation(fields: [dentistId], references: [id], onDelete: Restrict)
  patient               Patient                @relation(fields: [patientId], references: [id])
  billing               Billing[]
  packageItems          PackageItem[]
  patientPayments       PatientPayment[]
  intakeSubmissions     IntakeSubmission[]
  consentForms          ConsentForm[]

  @@index([appointmentNumber])
  @@index([patientId, scheduledDatetime])
  @@index([dentistId, scheduledDatetime])
  @@index([status])
  @@index([scheduledDatetime])
  @@index([isEmergency])
  @@index([source])
  @@map("appointments")
}

model ClinicService {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  displayName String?  @map("display_name") @db.VarChar(200)
  description String?
  category    String?  @db.VarChar(100)
  duration    Int      @default(30)
  isActive    Boolean  @default(true) @map("is_active")
  websiteVisible Boolean @default(true) @map("website_visible")
  isOfficial  Boolean  @default(false) @map("is_official")
  sortOrder   Int      @default(0) @map("sort_order")
  estimatedPrice Decimal? @map("estimated_price") @db.Decimal(10, 2)
  priceMin    Decimal? @map("price_min") @db.Decimal(10, 2)
  priceMax    Decimal? @map("price_max") @db.Decimal(10, 2)
  priceDisplay String? @map("price_display") @db.VarChar(120)
  showPrice   Boolean  @default(true) @map("show_price")
  imageUrl    String?  @map("image_url") @db.VarChar(500)
  tagalog     String?  @db.VarChar(200)
  // Linkage (JSON arrays of UUID strings)
  linkedTreatmentIds     Json? @map("linked_treatment_ids")
  linkedPackageTemplateIds Json? @map("linked_package_template_ids")
  linkedFormTemplateKeys Json?  @map("linked_form_template_keys")
  defaultAppointmentType String? @map("default_appointment_type") @db.VarChar(50)
  defaultPlanPhases      Json?  @map("default_plan_phases")
  defaultPlanTitle       String? @map("default_plan_title") @db.VarChar(200)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  appointments Appointment[]

  @@index([isActive, sortOrder])
  @@index([websiteVisible])
  @@index([isOfficial])
  @@map("clinic_services")
}

model Treatment {
  id                       String                    @id @default(uuid()) @db.Uuid
  treatmentCode            String                    @unique @map("treatment_code") @db.VarChar(20)
  name                     String                    @db.VarChar(200)
  description              String?
  category                 String                    @db.VarChar(100)
  // Procedure type: "general" (default) or "ortho". Used to group procedures into the General + Ortho tabs in the Procedures module.
  procedureType            String                    @default("general") @map("procedure_type") @db.VarChar(20)
  baseCost                 Decimal                   @default(0.00) @map("base_cost") @db.Decimal(10, 2)
  estimatedDurationMinutes Int                       @default(30) @map("estimated_duration_minutes")
  requiresAnesthesia       Boolean?                  @default(false) @map("requires_anesthesia")
  requiresFollowup         Boolean?                  @default(false) @map("requires_followup")
  isSurgical               Boolean?                  @default(false) @map("is_surgical")
  isActive                 Boolean                   @default(true) @map("is_active")
  createdAt                DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  appointmentTreatments    AppointmentTreatment[]
  dentalProcedures         DentalProcedure[]
  inventoryUsage           TreatmentInventoryUsage[]
  packageItems             PackageItem[]
  templateProcedures       PackageTemplateProcedure[]

  @@index([treatmentCode])
  @@index([category])
  @@index([isActive])
  @@index([baseCost])
  @@index([procedureType])
  @@map("treatments")
}

model AppointmentTreatment {
  id            String                     @id @default(uuid()) @db.Uuid
  appointmentId String                     @map("appointment_id") @db.Uuid
  treatmentId   String                     @map("treatment_id") @db.Uuid
  toothNumber   String?                    @map("tooth_number") @db.VarChar(10)
  surface       String?                    @db.VarChar(50)
  quantity      Int                        @default(1)
  unitCost      Decimal                    @map("unit_cost") @db.Decimal(10, 2)
  totalCost     Decimal                    @map("total_cost") @db.Decimal(10, 2)
  status        TreatmentStatus            @default(planned)
  notes         String?
  startedAt     DateTime?                  @map("started_at") @db.Timestamptz(6)
  completedAt   DateTime?                  @map("completed_at") @db.Timestamptz(6)
  createdAt     DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  items         AppointmentTreatmentItem[]
  appointment   Appointment                @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  treatment     Treatment                  @relation(fields: [treatmentId], references: [id])

  @@index([appointmentId])
  @@index([treatmentId])
  @@index([status])
  @@map("appointment_treatments")
}

model Schedule {
  id           String       @id @default(uuid()) @db.Uuid
  dentistId    String       @map("dentist_id") @db.Uuid
  scheduleDate DateTime     @map("schedule_date") @db.Date
  startTime    DateTime     @map("start_time") @db.Time(6)
  endTime      DateTime     @map("end_time") @db.Time(6)
  isAvailable  Boolean      @default(true) @map("is_available")
  scheduleType ScheduleType @default(regular) @map("schedule_type")
  notes        String?
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  dentist      Dentist      @relation(fields: [dentistId], references: [id], onDelete: Cascade)

  @@index([dentistId, scheduleDate])
  @@index([scheduleDate])
  @@index([isAvailable])
  @@map("schedules")
}

model Billing {
  id             String        @id @default(uuid()) @db.Uuid
  invoiceNumber  String        @unique @map("invoice_number") @db.VarChar(20)
  patientId      String        @map("patient_id") @db.Uuid
  appointmentId  String?       @map("appointment_id") @db.Uuid
  subtotal       Decimal       @default(0.00) @db.Decimal(10, 2)
  taxRate        Decimal       @default(0.0875) @map("tax_rate") @db.Decimal(5, 4)
  taxAmount      Decimal       @default(0.00) @map("tax_amount") @db.Decimal(10, 2)
  discountAmount Decimal       @default(0.00) @map("discount_amount") @db.Decimal(10, 2)
  discountReason String?       @map("discount_reason")
  totalAmount    Decimal       @default(0.00) @map("total_amount") @db.Decimal(10, 2)
  paidAmount     Decimal       @default(0.00) @map("paid_amount") @db.Decimal(10, 2)
  balanceDue     Decimal       @default(0.00) @map("balance_due") @db.Decimal(10, 2)
  status         BillingStatus @default(draft)
  dueDate        DateTime?     @map("due_date") @db.Date
  sentDate       DateTime?     @map("sent_date") @db.Date
  paymentTerms   Int?          @default(30) @map("payment_terms")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  appointment    Appointment?  @relation(fields: [appointmentId], references: [id])
  patient        Patient       @relation(fields: [patientId], references: [id])
  payments       Payment[]

  @@index([invoiceNumber])
  @@index([patientId, status])
  @@index([dueDate])
  @@index([appointmentId])
  @@map("billing")
}

model Payment {
  id               String        @id @default(uuid()) @db.Uuid
  billingId        String        @map("billing_id") @db.Uuid
  paymentReference String        @unique @map("payment_reference") @db.VarChar(50)
  amount           Decimal       @db.Decimal(10, 2)
  paymentMethod    PaymentMethod @map("payment_method")
  status           PaymentStatus @default(pending)
  transactionId    String?       @map("transaction_id") @db.VarChar(100)
  processor        String?       @db.VarChar(50)
  processorFee     Decimal?      @default(0.00) @map("processor_fee") @db.Decimal(10, 2)
  currency         String?       @default("USD") @db.VarChar(3)
  notes            String?
  processedAt      DateTime?     @map("processed_at") @db.Timestamptz(6)
  failedAt         DateTime?     @map("failed_at") @db.Timestamptz(6)
  failureReason    String?       @map("failure_reason")
  refundedAt       DateTime?     @map("refunded_at") @db.Timestamptz(6)
  refundAmount     Decimal?      @default(0.00) @map("refund_amount") @db.Decimal(10, 2)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  billing          Billing       @relation(fields: [billingId], references: [id])

  @@index([paymentReference])
  @@index([billingId])
  @@index([status])
  @@index([paymentMethod])
  @@index([processedAt])
  @@map("payments")
}

model AuditLog {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String?     @map("user_id") @db.Uuid
  entityType  String      @map("entity_type") @db.VarChar(50)
  entityId    String      @map("entity_id") @db.Uuid
  action      AuditAction
  category    String?     @db.VarChar(20)
  description String?     @db.VarChar(500)
  oldValues   Json?       @map("old_values")
  newValues   Json?       @map("new_values")
  ipAddress   String?     @map("ip_address") @db.Inet
  userAgent   String?     @map("user_agent")
  sessionId   String?     @map("session_id") @db.VarChar(255)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([category])
  @@map("audit_logs")
}

model Notification {
  id              String               @id @default(uuid()) @db.Uuid
  userId          String               @map("user_id") @db.Uuid
  title           String               @db.VarChar(200)
  message         String
  type            NotificationType
  module          String?              @db.VarChar(50)
  relatedRecordId String?              @map("related_record_id") @db.VarChar(100)
  redirectUrl     String?              @map("redirect_url") @db.VarChar(500)
  status          NotificationStatus   @default(pending)
  priority        NotificationPriority @default(normal)
  metadata        Json?
  scheduledAt     DateTime?            @map("scheduled_at") @db.Timestamptz(6)
  sentAt          DateTime?            @map("sent_at") @db.Timestamptz(6)
  deliveredAt     DateTime?            @map("delivered_at") @db.Timestamptz(6)
  readAt          DateTime?            @map("read_at") @db.Timestamptz(6)
  clickedAt       DateTime?            @map("clicked_at") @db.Timestamptz(6)
  expiresAt       DateTime?            @map("expires_at") @db.Timestamptz(6)
  archivedAt      DateTime?            @map("archived_at") @db.Timestamptz(6)
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([scheduledAt])
  @@index([type])
  @@index([priority])
  @@index([module])
  @@map("notifications")
}

model SystemSetting {
